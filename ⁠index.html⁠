    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Prompt:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        :root {
            --primary: #40916C;
            --primary-dark: #1B4332;
            --primary-light: #D8F3DC;
            --accent: #FF9F1C;
            --bg-color: #F4F9F1;
            --text-main: #2D3142;
            --text-dark: #081C15;
            --white: #FFFFFF;
            
            /* Risk Colors */
            --safe: #2a9d8f;
            --warning: #e9c46a;
            --danger: #e76f51;
            --critical: #1d3557;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Prompt', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* --- NAVIGATION --- */
        nav {
            background-color: var(--primary-dark);
            color: var(--white);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-area h1 {
            font-family: 'Comfortaa', cursive;
            font-size: 28px;
            letter-spacing: 1px;
        }

        .logo-area h1 span { color: var(--accent); }
        
        .badge-psu {
            background: rgba(255,255,255,0.15);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .nav-links {
            display: flex;
            gap: 20px;
            list-style: none;
        }

        .nav-links a {
            color: #b7e4c7;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s;
            cursor: pointer;
            padding: 8px 16px;
            border-radius: 12px;
        }

        .nav-links a:hover, .nav-links a.active {
            color: var(--white);
            background-color: rgba(255,255,255,0.1);
            box-shadow: inset 0 -3px 0 var(--accent);
        }

        /* --- APP MAIN LAYOUT --- */
        .container {
            max-width: 1300px;
            width: 100%;
            margin: 30px auto;
            padding: 0 20px;
            flex-grow: 1;
        }

        .web-page {
            display: none;
        }

        .web-page.active-page {
            display: block;
            animation: fadeIn 0.5s ease-in-out;
        }

        /* --- ANIME RPG HERO BANNER --- */
        .hero-banner {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: var(--white);
            border-radius: 30px;
            padding: 40px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(64, 145, 108, 0.2);
            margin-bottom: 30px;
            border-bottom: 8px solid var(--accent);
        }

        .hero-banner::after {
            content: '🌳';
            position: absolute;
            right: -20px;
            bottom: -30px;
            font-size: 200px;
            opacity: 0.15;
            transform: rotate(-15deg);
        }

        .hero-tag {
            background: var(--accent);
            color: var(--text-dark);
            padding: 5px 15px;
            border-radius: 30px;
            font-weight: bold;
            font-size: 14px;
            display: inline-block;
            margin-bottom: 15px;
        }

        /* --- INTERFACE CARDS & TILES (RPG Style) --- */
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }

        .rpg-card {
            background: var(--white);
            border-radius: 24px;
            border: 3px solid #E2E8F0;
            border-bottom: 7px solid #CBD5E1;
            padding: 25px;
            transition: all 0.2s ease;
        }

        .rpg-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            border-bottom-width: 7px;
        }

        .card-title-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            border-bottom: 2px dashed #E2E8F0;
            padding-bottom: 12px;
        }

        .card-title-bar i {
            font-size: 24px;
            color: var(--accent);
        }

        /* --- UPLOAD SYSTEM (3 CAMERAS) --- */
        .upload-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .cam-box {
            background: var(--bg-color);
            border: 3px dashed #CBD5E1;
            border-radius: 16px;
            padding: 20px 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .cam-box:hover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

        .cam-box i { font-size: 32px; color: #94A3B8; margin-bottom: 8px; }
        .cam-box.loaded { border-style: solid; border-color: var(--primary); background: #f8fff9; }
        .cam-box.loaded i { color: var(--primary); }

        /* --- BUTTONS --- */
        .rpg-btn {
            background: var(--accent);
            color: var(--white);
            border: none;
            padding: 14px 28px;
            border-radius: 16px;
            font-weight: bold;
            font-size: 18px;
            cursor: pointer;
            box-shadow: 0 5px 0 #D97706;
            transition: all 0.1s;
            width: 100%;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .rpg-btn:active {
            transform: translateY(4px);
            box-shadow: 0 1px 0 #D97706;
        }

        .rpg-btn-secondary {
            background: var(--primary);
            box-shadow: 0 5px 0 var(--primary-dark);
        }

        /* --- LIVE COUNTERS & STATS --- */
        .stat-badge-group {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }
        .stat-badge {
            flex: 1;
            background: var(--bg-color);
            padding: 12px;
            border-radius: 12px;
            text-align: center;
            border: 2px solid #E2E8F0;
        }
        .stat-num { font-size: 24px; font-weight: bold; color: var(--primary-dark); }

        /* --- GACHA & PET SECTION --- */
        .gacha-box {
            background: linear-gradient(to bottom, #FFF, #FFFBEB);
            text-align: center;
            padding: 30px;
        }
        .pet-avatar {
            width: 120px;
            height: 120px;
            background: var(--primary-light);
            border-radius: 50%;
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            border: 4px solid var(--primary);
            animation: bounce 2s infinite;
        }

        /* --- DISCLAIMER FOOTER BAR --- */
        .disclaimer-bar {
            background-color: #FEF3C7;
            border-left: 6px solid #D97706;
            padding: 15px 20px;
            border-radius: 12px;
            margin-top: 35px;
            font-size: 14px;
            color: #92400E;
        }

        /* --- AUDIT LOG TABLE --- */
        .audit-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        .audit-table th, .audit-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #E2E8F0;
        }
        .audit-table th { background-color: var(--primary-dark); color: white; }
        .audit-table tr:nth-child(even) { background-color: #F8FAFC; }

        /* KEYFRAMES ANIMATION */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        /* MAP SIMULATION */
        .mock-map {
            width: 100%;
            height: 350px;
            background: #E2E8F0;
            border-radius: 16px;
            position: relative;
            overflow: hidden;
            border: 3px solid #CBD5E1;
        }
        .map-bg { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; }
        .map-pin {
            position: absolute;
            font-size: 28px;
            cursor: pointer;
            animation: bounce 2.5s infinite;
        }

        footer {
            background-color: var(--primary-dark);
            color: #b7e4c7;
            text-align: center;
            padding: 20px;
            margin-top: auto;
            font-size: 14px;
        }
    </style>
</head>
