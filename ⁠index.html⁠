    </footer>

    <script>
        // ระบบสลับหน้าแอปพลิเคชัน (SPA Style)
        function switchPage(pageId) {
            // ซ่อนทุกหน้าก่อน
            document.querySelectorAll('.web-page').forEach(page => {
                page.classList.remove('active-page');
            });
            document.querySelectorAll('.nav-links a').forEach(link => {
                link.classList.remove('active');
            });

            // เปิดหน้าที่เลือก
            document.getElementById('page-' + pageId).classList.add('active-page');
            document.getElementById('nav-' + pageId).classList.add('active');
        }

        // ระบบจำลองสถานการณ์การอัปโหลดรูปภาพ 3 มุม
        let uploaded = { cam1: false, cam2: false, cam3: false };
        function mockUpload(id) {
            uploaded[id] = true;
            const element = document.getElementById(id);
            element.classList.add('loaded');
            element.innerHTML = `<i class="fa-solid fa-circle-check" style="color:var(--primary);"></i><h5>บันทึกแล้ว!</h5><small style="color:var(--primary);">พร้อมส่งเข้าระบบ AI</small>`;
        }

        // ระบบจำลองการรอผลลัพธ์จากโมเดล AI (Gemini Flash API Response Process)
        function runAISimulation() {
            if(!uploaded.cam1 || !uploaded.cam2 || !uploaded.cam3) {
                alert("กรุณาจำลองการอัปโหลดให้ครบถ้วนทั้ง 3 มุมก่อนส่งวิเคราะห์ครับ!");
                return;
            }
            
            const btn = document.getElementById('btn-process');
            btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> กำลังวิเคราะห์ผ่าน Prompt Engineering & Visual Axis...`;
            btn.disabled = true;

            setTimeout(() => {
                btn.innerHTML = `<i class="fa-solid fa-brain"></i> ประมวลผลเสร็จสิ้น!`;
                btn.classList.remove('rpg-btn-secondary');
                btn.style.backgroundColor = 'var(--safe)';
                
                // แสดงบล็อกผลลัพธ์
                const resultBox = document.getElementById('ai-result');
                resultBox.style.display = 'block';
                
                // จัดการ Badge สีตามระดับความเสี่ยงของ Human-in-the-Loop 
                const badge = document.getElementById('risk-badge');
                badge.style.backgroundColor = 'var(--danger)';
                badge.innerHTML = `🔴 ระดับเสี่ยงสูง (Risk Score: 78% | คิวตรวจสอบด่วน Urgent Queue)`;
                
                // จำลองระบบส่งออกอัตโนมัติแจ้งเตือนเจ้าหน้าที่ทันที
                alert("⚠️ [Telegram Bot Security Alert] ตรวจพบต้นไม้เสี่ยงสูง! ระบบได้ส่งสตรีมข้อมูลไปยังศูนย์บรรเทาสาธารณภัยเทศบาลหาดใหญ่แล้ว");
                
                resultBox.scrollIntoView({ behavior: 'smooth' });
            }, 2500); // จำลองเวลาประมวลผลด่วน 2.5 วินาที
        }
    </script>
