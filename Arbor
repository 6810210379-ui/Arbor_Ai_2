<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARBOR AI - Digital Arborist Interface</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mitr:wght@300;400;600&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Mitr', 'Outfit', sans-serif;
            background-color: #2D4A43; /* ธีมสีป่าทึบแบบหน้าโหลดเกม */
        }
        /* คัสตอมกรอบไม้สไตล์ RPG */
        .rpg-panel {
            background-color: #FDF5E6;
            border: 4px solid #8B5A2B;
            box-shadow: inset 0 0 10px rgba(139,90,43,0.3), 0 8px 16px rgba(0,0,0,0.3);
        }
        .rpg-header {
            background: linear-gradient(180deg, #A06A3B 0%, #8B5A2B 100%);
            border-bottom: 4px solid #5C3A1B;
        }
    </style>
</head>
<body class="min-h-screen p-3 md:p-6 text-[#3E2723]">

    <div class="max-w-7xl mx-auto space-y-4">
        
        <header class="w-full bg-[#1E3A34] text-white p-4 rounded-2xl flex flex-wrap justify-between items-center border-b-4 border-[#122420] shadow-lg">
            <div class="flex items-center space-x-3">
                <div class="bg-green-500 p-2 rounded-xl animate-pulse">
                    <i data-lucide="tree-pine" class="w-6 h-6 text-white"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-wider">ARBOR AI</h1>
                    <p class="text-[11px] text-green-400">Digital Arborist v4.0 · Competition Ready</p>
                </div>
            </div>

            <div class="bg-[#122420] px-4 py-2 rounded-xl border border-green-800/60 flex items-center space-x-2 text-sm">
                <i data-lucide="map-pin" class="w-4 h-4 text-red-400"></i>
                <span class="font-medium text-gray-200">PSU Hat Yai, Songkhla</span>
            </div>

            <div class="flex items-center space-x-3 mt-2 sm:mt-0">
                <div class="bg-[#2E1A08] px-4 py-2 rounded-xl border-2 border-[#A06A3B] flex items-center space-x-2">
                    <i data-lucide="coins" class="w-5 h-5 text-yellow-400 animate-spin" style="animation-duration: 4s;"></i>
                    <span id="balance-display" class="font-bold text-yellow-300 font-mono text-base">310g</span>
                    <span class="text-[10px] text-gray-400">Arbor Pt</span>
                </div>
                <div class="hidden md:block bg-black/30 px-3 py-2 rounded-xl text-xs text-green-300 border border-green-900">
                    สิทธิ์วันนี้: <span id="quota-display" class="font-bold">3/3</span> เคส
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <div class="lg:col-span-2 space-y-4 flex flex-col">
                
                <div class="w-full flex-1 rounded-3xl overflow-hidden border-4 border-[#8B5A2B] shadow-2xl relative min-h-[450px] md:min-h-[520px]">
                    <div class="rpg-header p-3 text-white flex justify-between items-center z-10 relative">
                        <span class="font-bold text-sm flex items-center"><i data-lucide="navigation" class="w-4 h-4 mr-1.5"></i> แผนที่เฝ้าระวังภัยรุกขกรรมเมือง (หาดใหญ่)</span>
                        <span class="text-xs bg-red-600 font-bold px-2 py-0.5 rounded animate-bounce">มรสุมโหมด ON</span>
                    </div>
                    <div id="map" class="w-full h-full z-0" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; pt: 48px;"></div>
                </div>

                <div class="grid grid-cols-3 gap-3">
                    <div class="bg-white/90 backdrop-blur p-3 rounded-2xl border-2 border-green-700/20 text-center shadow">
                        <p class="text-[11px] font-bold text-green-800">ต้นไม้ที่สำรวจแล้ว</p>
                        <p class="text-xl font-black text-green-700">1,240 ต้น</p>
                    </div>
                    <div class="bg-white/90 backdrop-blur p-3 rounded-2xl border-2 border-yellow-600/20 text-center shadow">
                        <p class="text-[11px] font-bold text-yellow-800">สถานะเฝ้าระวัง</p>
                        <p class="text-xl font-black text-yellow-600">42 ต้น</p>
                    </div>
                    <div class="bg-white/90 backdrop-blur p-3 rounded-2xl border-2 border-red-600/20 text-center shadow">
                        <p class="text-[11px] font-bold text-red-800">วิกฤต/เสี่ยงล้ม</p>
                        <p class="text-xl font-black text-red-600">5 ต้น</p>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                
                <div class="rpg-panel rounded-2xl overflow-hidden">
                    <div class="rpg-header p-3 text-white font-bold text-sm flex items-center justify-between">
                        <span class="flex items-center"><i data-lucide="cpu" class="w-4 h-4 mr-1.5"></i> ARBOR AI - DIGITAL ARBORIST</span>
                        <button onclick="triggerReset()" class="text-xs text-amber-200 hover:text-white"><i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i></button>
                    </div>
                    
                    <div class="p-4 space-y-4">
                        <div class="flex items-center space-x-3 bg-white/50 p-2 rounded-xl border border-[#8B5A2B]/10">
                            <div class="w-10 h-10 bg-amber-700 rounded-full flex items-center justify-center text-white font-bold text-sm border-2 border-amber-900">T</div>
                            <div>
                                <p class="text-xs text-gray-500">ผู้รายงานระบบพลเมือง</p>
                                <p class="text-sm font-bold">User: Tanakorn (วิทยาศาสตร์ ม.อ.)</p>
                            </div>
                        </div>

                        <button id="btn-analyze" onclick="startAIAnalysis()" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-4 rounded-xl border-b-4 border-green-800 transition transform active:scale-98 flex items-center justify-center space-x-2 text-sm">
                            <i data-lucide="camera" class="w-4 h-4"></i>
                            <span>ส่งรูปถ่าย 3 มุม & ประเมินด่วน</span>
                        </button>

                        <div id="ai-loading" class="hidden space-y-1.5">
                            <div class="flex justify-between text-xs font-bold text-amber-800">
                                <span class="flex items-center"><i data-lucide="loader-2" class="w-3 h-3 mr-1 animate-spin"></i> AI กำลังคำนวณแกนองศาเอียง...</span>
                                <span id="progress-text">0%</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-3 border border-amber-900/20 overflow-hidden">
                                <div id="progress-bar" class="bg-gradient-to-r from-teal-400 to-green-500 h-full rounded-full transition-all duration-300" style="width: 0%"></div>
                            </div>
                        </div>

                        <div id="ai-result" class="hidden bg-white/80 p-3 rounded-xl border-2 border-orange-500/40 space-y-2">
                            <div class="flex justify-between items-center border-b border-gray-200 pb-1.5">
                                <span class="text-xs bg-orange-600 text-white font-bold px-2 py-0.5 rounded">RISK: WATCH (เฝ้าระวัง)</span>
                                <span class="text-xs text-gray-500">Report #1045 (PSU Road)</span>
                            </div>
                            <div class="grid grid-cols-2 gap-2 text-xs">
                                <div><b class="text-gray-600">สายพันธุ์ที่ตรวจพบ:</b> <p class="font-bold text-sm">นนทรีภาคใต้</p></div>
                                <div><b class="text-gray-600">องศาเอียง / สูง:</b> <p class="font-bold text-sm text-amber-700">12.5° / 15.2 ม.</p></div>
                            </div>
                            <div class="space-y-1 text-[11px] bg-amber-50 p-2 rounded-lg border border-amber-200">
                                <div class="flex justify-between font-bold text-amber-900">
                                    <span>ความมั่นใจของโมเดล (Confidence):</span>
                                    <span>87.5%</span>
                                </div>
                                <div class="w-full bg-gray-200 h-1.5 rounded-full overflow-hidden">
                                    <div class="bg-green-500 h-full" style="width: 87.5%"></div>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-2 pt-1">
                                <button class="bg-amber-100 hover:bg-amber-200 text-[#8B5A2B] border border-[#8B5A2B]/40 text-xs font-bold py-2 rounded-lg flex items-center justify-center">
                                    <i data-lucide="file-text" class="w-3.5 h-3.5 mr-1 text-red-600"></i> ออกรายงาน PDF
                                </button>
                                <button onclick="alert('ระบบส่งพิกัดและข้อมูลเบื้องต้นไปยังหน่วยงานบรรเทาสาธารณภัยหาดใหญ่เรียบร้อยแล้ว [MOCK ALERT]')" class="bg-red-600 hover:bg-red-700 text-white text-xs font-bold py-2 rounded-lg flex items-center justify-center border-b-2 border-red-800">
                                    🚨 แจ้งเหตุเทศบาล
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="rpg-panel rounded-2xl overflow-hidden">
                    <div class="rpg-header p-3 text-white font-bold text-sm flex items-center justify-between">
                        <span class="flex items-center"><i data-lucide="message-square" class="w-4 h-4 mr-1.5"></i> PRIVATE CHAT - เคสต้นไม้ #1045</span>
                        <span class="text-[10px] bg-green-500 px-1.5 py-0.2 rounded text-white">แอดมิน kkty</span>
                    </div>
                    <div class="p-3 space-y-3">
                        <div class="h-28 bg-white/60 rounded-xl p-2 overflow-y-auto text-xs space-y-2 border border-stone-300">
                            <div><b class="text-blue-700">[Tan]:</b> ต้นไม้พิกัดนี้มีรอยผุใหญ่ที่โคนครับ ถ่ายรูปส่งไปแล้วครับ</div>
                            <div class="bg-amber-100/60 p-1.5 rounded border border-amber-200"><b class="text-amber-900">[Admin kkty]:</b> รับเรื่องครับ กำลังส่งคิวให้ผู้ช่วยแอดมินรุกขกรลงพื้นที่ตรวจสอบหน้างานจริงครับ</div>
                        </div>
                        <div class="flex space-x-1.5">
                            <input type="text" placeholder="พิมพ์ข้อความตอบกลับแอดมิน..." class="flex-1 text-xs px-3 py-2 rounded-xl border border-stone-400 focus:outline-none focus:ring-2 focus:ring-amber-700 bg-white">
                            <button class="bg-teal-600 hover:bg-teal-700 text-white p-2 rounded-xl"><i data-lucide="send" class="w-4 h-4"></i></button>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-b from-[#FFFEEF] to-[#FFF9D2] border-4 border-yellow-600 rounded-2xl overflow-hidden shadow-lg">
                    <div class="bg-gradient-to-r from-yellow-600 to-amber-700 p-2.5 text-white font-bold text-xs flex justify-between items-center">
                        <span class="flex items-center"><i data-lucide="sparkles" class="w-3.5 h-3.5 mr-1 text-yellow-300"></i> ECO GACHA - กล่องจุ่มรุกขกรน้อย</span>
                        <span class="text-[9px] bg-yellow-900 px-1.5 py-0.5 rounded text-yellow-200 font-mono">Rates: SSR 5% | SR 20%</span>
                    </div>
                    <div class="p-3 text-center space-y-3">
                        <div class="bg-white/70 p-3 rounded-xl border-2 border-dashed border-yellow-500 min-h-[75px] flex items-center justify-center flex-col">
                            <div id="gacha-idle" class="text-xs text-gray-500">
                                <p>สะสมแต้ม Arbor Points จากการสำรวจเมือง</p>
                                <p class="text-[10px] text-amber-700 font-semibold mt-1">ใช้ 500g ต่อการหมุนสุ่มเปิดกล่อง 1 ครั้ง</p>
                            </div>
                            <div id="gacha-result" class="hidden text-sm font-bold text-green-900 animate-bounce"></div>
                        </div>
                        
                        <button id="btn-gacha" onclick="pullGacha()" class="w-full bg-gradient-to-r from-yellow-500 to-orange-500 hover:from-yellow-600 hover:to-orange-600 text-white font-black py-3 rounded-xl border-b-4 border-orange-700 text-xs shadow tracking-wider transition transform active:scale-95">
                            🎰 เปิดกล่องจุ่มพิทักษ์โลก (500 Credits)
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <footer class="w-full text-center text-[11px] text-gray-400 bg-black/20 p-4 rounded-xl space-y-1">
            <p>🛡️ <b>ระบบคุ้มครองข้อมูลส่วนบุคคล (PDPA):</b> ภาพถ่ายต้นไม้ปลอดภัยจะถูกลบอัตโนมัติภายใน 90 วัน พิกัด GPS สาธารณะแสดงผลแบบ Approximate Location เพื่อความเป็นส่วนตัว</p>
            <p>🌿 ผลลัพธ์เป็นการประเมินเบื้องต้นเชิงคณิตศาสตร์และวิจัยสิ่งแวดล้อมโดยสถิติของ AI ไม่สามารถใช้แทนการยืนยันตัดต้นไม้จริงของรุกขกรผู้เชี่ยวชาญได้</p>
        </footer>

    </div>

    <script>
        // เริ่มต้นเรียกใช้ไอคอนทั้งหมดของ Lucide
        lucide.createIcons();

        // 1. INITIALIZE LEAFLET MAP (สร้างระบบแผนที่นำร่องหาดใหญ่)
        // ตั้งค่าพิกัดเริ่มต้นไว้ที่ ม.อ. หาดใหญ่ [7.0086, 100.4913]
        const map = L.map('map', { zoomControl: false }).setView([7.0086, 100.4913], 15);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // ย้ายปุ่มควบคุมการซูมไปไว้ที่มุมขวาบนไม่ให้บังหน้าจอเกมน่ารักๆ
        L.control.zoom({ position: 'topright' }).addTo(map);

        // ปักหมุดจำลองจุดต้นไม้เสี่ยงตามข้อมูลในรูปภาพ
        const markersData = [
            { coords: [7.0090, 100.4920], title: "ต้นไม้เสี่ยงสูง #1045 (PSU Main Road)", level: "warn" },
            { coords: [7.0065, 100.4895], title: "ต้นไม้ปลอดภัย #1046", level: "safe" },
            { coords: [7.0110, 100.4910], title: "ต้นไม้เฝ้าระวัง #1047", level: "watch" }
        ];

        markersData.forEach(data => {
            let color = data.level === 'safe' ? '#4ADE80' : data.level === 'watch' ? '#FACC15' : '#EF4444';
            let circleMarker = L.circleMarker(data.coords, {
                radius: 10,
                fillColor: color,
                color: '#fff',
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(map);
            circleMarker.bindPopup(`<b class="font-bold text-xs">${data.title}</b>`);
        });

        // 2. CORE LOGIC & ANTI-ABUSE ENGINE VARIABLES
        let arborPoints = 810; // แต้มเริ่มต้นจำลอง
        let dailyQuota = 3;    // โควตาจำนวนครั้งต่อวัน

        // ฟังก์ชันจำลองระบบการวิเคราะห์ประเมินภาพของ AI
        function startAIAnalysis() {
            if (dailyQuota <= 0) {
                alert("🔒 [Anti-Abuse Error] บัญชีของคุณใช้สิทธิ์รายงานเพื่อรับแต้มครบ 3 ครั้งต่อวันนี้แล้ว เพื่อป้องกันการปั๊มแต้มซ้ำกรุณากลับมาลองใหม่วันพรุ่งนี้ครับ");
                return;
            }

            const btn = document.getElementById('btn-analyze');
            const loader = document.getElementById('ai-loading');
            const result = document.getElementById('ai-result');
            const progText = document.getElementById('progress-text');
            const progBar = document.getElementById('progress-bar');

            btn.classList.add('hidden');
            result.classList.add('hidden');
            loader.classList.remove('hidden');

            let progress = 0;
            const interval = setInterval(() => {
                progress += 5;
                progText.innerText = progress + '%';
                progBar.style.width = progress + '%';

                if (progress >= 100) {
                    clearInterval(interval);
                    loader.classList.add('hidden');
                    result.classList.remove('hidden');
                    
                    // ปลดล็อกให้รับแต้มสะสมเพิ่มเมื่อการรายงานสำเร็จตามเกณฑ์สถิติพลเมือง
                    arborPoints += 100;
                    dailyQuota -= 1;
                    document.getElementById('balance-display').innerText = arborPoints + 'g';
                    document.getElementById('quota-display').innerText = dailyQuota + '/3';
                }
            }, 150);
        }

        // ฟังก์ชันระบบสุ่มกล่องจุ่มแบบโปร่งใส (Transparent Drop Rate) คำนวณผลอย่างรัดกุม
        function pullGacha() {
            if (arborPoints < 500) {
                alert("❌ แต้ม Arbor Point ของคุณไม่เพียงพอ! คุณจำเป็นต้องรวบรวมแต้มให้ครบ 500g จากการลงพื้นที่ถ่ายภาพสำรวจเมืองก่อนครับ");
                return;
            }

            arborPoints -= 500;
            document.getElementById('balance-display').innerText = arborPoints + 'g';

            const idleText = document.getElementById('gacha-idle');
            const resultText = document.getElementById('gacha-result');
            
            idleText.classList.add('hidden');
            resultText.classList.remove('hidden');
            resultText.innerText = "🎰 กำลังจุ่มลุ้นรับตัวละคร...";

            setTimeout(() => {
                const rng = Math.random() * 100; // สุ่มตัวเลขโปร่งใสจากระบบหลังบ้าน
                let prize = "";
                
                if (rng <= 5) {
                    prize = "🌴 ตัวละครในตำนาน: มะฮอกกานีทองคำเปล่งแสง (SSR)!";
                    resultText.className = "text-sm font-black text-amber-600 animate-bounce";
                } else if (rng <= 25) {
                    prize = "🌱 ตัวละครหายาก: น้องสปราวท์กิ่งไม้พริ้ว (SR)";
                    resultText.className = "text-sm font-bold text-teal-600 animate-pulse";
                } else {
                    prize = "🍂 สัตว์เลี้ยงทั่วไป: โอ๊คกี้ใบไม้แห้ง (R)";
                    resultText.className = "text-xs font-bold text-gray-600";
                }
                
                resultText.innerText = prize;
            }, 1200);
        }

        // รีเซ็ตหน้าจอเพื่อเริ่มทดสอบกระบวนการใหม่
        function triggerReset() {
            document.getElementById('btn-analyze').classList.remove('hidden');
            document.getElementById('ai-result').classList.add('hidden');
            document.getElementById('ai-loading').classList.add('hidden');
            document.getElementById('gacha-idle').classList.remove('hidden');
            document.getElementById('gacha-result').classList.add('hidden');
        }

    </script>
</body>
</html>
